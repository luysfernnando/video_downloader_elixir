# ============================================
# Configuração para Deploy na VPS
# ============================================
# Copie este arquivo para .env e configure os valores

# Docker Hub Username (obrigatório)
DOCKER_USERNAME=seu-usuario-dockerhub

# Versão da imagem (opcional, padrão: latest)
VERSION=latest

# Porta exposta no host (opcional, padrão: 4000)
APP_PORT=4000

# Host/domínio da aplicação (obrigatório)
# Use o IP da VPS ou domínio configurado
PHX_HOST=seu-ip-ou-dominio.com

# Secret Key Base (obrigatório)
# Gere com: mix phx.gen.secret
SECRET_KEY_BASE=sua-secret-key-aqui

# Ambiente (não alterar)
MIX_ENV=prod

# ============================================
# Configurações de Desenvolvimento (local)
# ============================================
# Configurações de Debug
DEBUG_LOGS=true
